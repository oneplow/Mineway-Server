# ---- VPS Tunnel Server Config ----

# Port ที่ plugin จะ WebSocket มาเชื่อม
WS_PORT=8765

# URL ของ Next.js web app (สำหรับ verify API key)
WEB_API_URL=https://your-web.com

# Secret สำหรับ internal API — ต้องตรงกับ INTERNAL_SECRET ใน Next.js .env
INTERNAL_SECRET=change-this-to-a-long-random-string

# TCP port range สำหรับ player connections (1 port = 1 tunnel session)
PORT_RANGE_START=25500
PORT_RANGE_END=25999

# Cache timeout สำหรับ key verification (วินาที)
KEY_CACHE_TTL=60

# Node env
NODE_ENV=production

# Base domain สำหรับ subdomain routing
BASE_DOMAIN=mineway.io

# TCP port รับ Java Edition players (port เดียวทุก tunnel)
MC_TCP_PORT=25565

# UDP port range สำหรับ Bedrock Edition (แต่ละ tunnel ได้ port ของตัวเอง)
BEDROCK_PORT_START=19200
BEDROCK_PORT_END=19999
