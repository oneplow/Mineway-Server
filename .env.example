# ── Mineway Tunnel Server ─────────────────────────────────────

# Port ที่ Tunnel Server รัน (internal, Caddy จะ proxy มาให้)
WS_PORT=8765

# Domain สำหรับ Caddy auto-SSL (เปลี่ยนเป็นของคุณ)
TUNNEL_DOMAIN=tunnel.mineway.cloud

# URL ของ Next.js Web App (สำหรับ verify API key)
WEB_API_URL=https://your-web.com

# Secret สำหรับ Internal API — ต้องตรงกับ INTERNAL_SECRET ใน Next.js .env
INTERNAL_SECRET=change-this-to-a-long-random-string

# Fallback Domain กรณีที่ API Key ไม่มีโดเมนผูกไว้ในระบบ
BASE_DOMAIN=mineway.cloud

# Cache timeout สำหรับ key verification (วินาที)
KEY_CACHE_TTL=60

# Node env
NODE_ENV=production
